@page "/login"
@using BootstrapBlazor.Components
@using BootstrapBlazor.McpServer.Services
@inject AjaxService AjaxService
@inject AppSettingsManager AppSettingsManager

<PageTitle>Login - MCP Dashboard</PageTitle>

<div class="d-flex align-items-center justify-content-center" style="height: 100vh; background-color: #f8f9fc;">
    <div class="card shadow-sm" style="width: 400px; border-radius: 12px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <i class="fa-solid fa-server text-primary" style="font-size: 3rem;"></i>
                <h4 class="mt-3 fw-bold">BootstrapBlazor RAG MCP</h4>
                <p class="text-muted">Enter credentials to access configuration</p>
            </div>

            <ValidateForm Model="@Model" OnValidSubmit="OnLoginSubmit">
                <div class="mb-3">
                    <BootstrapInput @bind-Value="Model.Username" PlaceHolder="Username (e.g., admin)" />
                </div>
                <div class="mb-4">
                    <BootstrapInput @bind-Value="Model.Password" type="password" PlaceHolder="Password" />
                </div>
                
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger p-2 mb-3">@ErrorMessage</div>
                }

                <Button Color="Color.Primary" ButtonType="ButtonType.Submit" class="w-100" Text="Sign In" IsAsync="true" />
            </ValidateForm>
        </div>
    </div>
</div>

@code {
    private LoginModel Model { get; set; } = new();
    private string ErrorMessage { get; set; } = "";

    public class LoginModel
    {
        public string Username { get; set; } = "admin";
        public string Password { get; set; } = "123456";
    }

    private async Task OnLoginSubmit(EditContext context)
    {
        ErrorMessage = "";
        
        try
        {
            var option = new AjaxOption 
            { 
                Url = $"/api/login?username={Uri.EscapeDataString(Model.Username)}&password={Uri.EscapeDataString(Model.Password)}",
                Method = "POST" 
            };
            
            var result = await AjaxService.InvokeAsync(option);
            await AjaxService.Goto("/");
        }
        catch (Exception)
        {
            ErrorMessage = "Authentication failed. Please check your username and password.";
        }
    }
}
