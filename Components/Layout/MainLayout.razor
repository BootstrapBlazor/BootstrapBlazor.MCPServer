@inherits LayoutComponentBase
@using BootstrapBlazor.Components
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<MainLayout> Localizer

<BootstrapBlazorRoot>
    <Layout SideWidth="0" IsPage="true" ShowGotoTop="true" ShowCollapseBar="true"
            ShowFooter="true" UseThemeToggle="true" FixedHeader="true" FixedFooter="true">
        <Header>
            <div class="d-flex align-items-center flex-fill px-3" style="height: 56px;">
                <div class="me-auto d-flex align-items-center gap-2">
                    <i class="fa-solid fa-cube text-primary"></i>
                    <span class="fw-bold">@Localizer["AppTitle"]</span>
                </div>
                <div class="d-flex gap-2">
                    <NavLink href="/" Match="NavLinkMatch.All" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-gauge"></i> @Localizer["Dashboard"]
                    </NavLink>
                    <NavLink href="/config" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-gears"></i> @Localizer["Settings"]
                    </NavLink>
                </div>
            </div>
        </Header>
        <Main>
            <div class="p-4">
                @Body
            </div>
        </Main>
        <Footer>
            <div class="text-center w-100">
                <i class="fa-solid fa-cube me-1"></i>
                BootstrapBlazor RAG MCP Engine v1.0
            </div>
        </Footer>
    </Layout>
</BootstrapBlazorRoot>
