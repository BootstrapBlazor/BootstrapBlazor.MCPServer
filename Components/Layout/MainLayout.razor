@inherits LayoutComponentBase
@using BootstrapBlazor.Components
@using Microsoft.Extensions.Localization
@inject AjaxService AjaxService
@inject IStringLocalizer<MainLayout> Localizer

<BootstrapBlazorRoot>
    <Layout SideWidth="0" IsPage="true" ShowGotoTop="true" ShowCollapseBar="true" 
            ShowFooter="true" UseThemeToggle="true" FixedHeader="true" FixedFooter="true">
        <Header>
            <div class="d-flex align-items-center flex-fill" style="padding: 0 1rem; height: 100%; color: white; background-color: var(--bs-primary);">
                <span class="fs-5 font-weight-bold">@Localizer["AppTitle"]</span>
                <span class="ms-auto d-flex align-items-center gap-3">
                    <a href="/" class="text-white text-decoration-none">@Localizer["Dashboard"]</a>
                    <a href="/repositories" class="text-white text-decoration-none">@Localizer["Repositories"]</a>
                    <a href="/config" class="text-white text-decoration-none">@Localizer["Settings"]</a>
                    <Button Color="Color.Danger" Icon="fa-solid fa-arrow-right-from-bracket" Size="Size.Small" Text="@Localizer["Logout"]" OnClick="OnLogout" />
                </span>
            </div>
        </Header>
        <Main>
            <div class="container-fluid p-4">
                @Body
            </div>
        </Main>
        <Footer>
            <div class="text-center w-100 flex-fill d-flex align-items-center justify-content-center">
                <span>BootstrapBlazor RAG MCP Engine v1.0</span>
            </div>
        </Footer>
    </Layout>
</BootstrapBlazorRoot>

@code {
    private async Task OnLogout()
    {
        var option = new AjaxOption
        {
            Url = "/api/logout",
            Method = "POST"
        };
        await AjaxService.InvokeAsync(option);
        await AjaxService.Goto("/login");
    }
}
